NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
DEMO_USER_ID=demo-user
# MongoDB connection string for backend persistence.
MONGODB_URI=mongodb://127.0.0.1:27017/religence

# Storage string (path/connection). Used by master-data importer when set.
STORAGE_CONNECTION_STRING=

# Auth (self-hosted JWT)
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_STORE_PATH=data/auth.json

# SMTP for verification / reset emails. Leave SMTP_URL empty to log to console.
SMTP_URL=
AUTH_EMAIL_FROM=Religence <no-reply@religence.local>

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/v1/email/auth/microsoft/callback
MICROSOFT_TENANT_ID=common
