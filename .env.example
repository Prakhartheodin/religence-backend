NODE_ENV=development
PORT=4000
# Frontend origin for CORS. Use one absolute URL with scheme (https:// in production).
# If comma-separated by mistake, the first https:// entry is used.
CORS_ORIGIN=http://localhost:3000
# Frontend base URL for OAuth redirects and email links. Must include https:// in production.
APP_BASE_URL=http://localhost:3000
# Production example:
# CORS_ORIGIN=https://crm.religence.in
# APP_BASE_URL=https://crm.religence.in
# MongoDB connection string for backend persistence.
MONGODB_URI=mongodb://127.0.0.1:27017/religence

# Excel directory for one-time buyer seeding only (not read at API runtime).
# Default when unset: ../Excel relative to religence-backend.
# Run: npm run seed:buyers:apply
MASTER_DATA_EXCEL_DIR=

# Auth (self-hosted JWT)
AUTH_JWT_SECRET=change-me-to-a-long-random-string
# Encrypts Outlook OAuth tokens at rest (AES-256-GCM). Falls back to
# AUTH_JWT_SECRET if unset; set a dedicated random string in production.
TOKEN_ENC_KEY=change-me-to-a-different-long-random-string

# SMTP for verification / reset emails. Leave SMTP_HOST empty to log to console.
# Port 465 = implicit TLS; anything else uses STARTTLS. SMTP_TIMEOUT is seconds.
SMTP_HOST=
SMTP_PORT=465
SMTP_TIMEOUT=10
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=Religence <no-reply@religence.local>

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/v1/email/auth/microsoft/callback
MICROSOFT_TENANT_ID=common
