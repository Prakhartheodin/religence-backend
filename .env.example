NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
# MongoDB connection string for backend persistence.
MONGODB_URI=mongodb://127.0.0.1:27017/religence

# Auth (self-hosted JWT)
AUTH_JWT_SECRET=change-me-to-a-long-random-string

# SMTP for verification / reset emails. Leave SMTP_HOST empty to log to console.
# Port 465 = implicit TLS; anything else uses STARTTLS. SMTP_TIMEOUT is seconds.
SMTP_HOST=
SMTP_PORT=465
SMTP_TIMEOUT=10
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=Religence <no-reply@religence.local>

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/v1/email/auth/microsoft/callback
MICROSOFT_TENANT_ID=common
